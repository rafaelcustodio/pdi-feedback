generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// User & Authentication
// ============================================================

enum UserRole {
  admin
  manager
  employee
}

enum EvaluationMode {
  pdi
  feedback
}

enum ScheduleType {
  pdi
  feedback
}

enum Ethnicity {
  branco
  preto
  amarelo
  indigena
  pardo
}

enum Gender {
  masculino
  feminino
  outra
}

enum MaritalStatus {
  solteiro
  casado
  outra
}

enum EducationLevel {
  ensino_medio
  ensino_tecnico
  superior_incompleto
  superior_completo
  pos_graduado
}

enum ContractType {
  efetivo
  estagio
}

enum HealthPlanOption {
  regional
  nacional
  nao
}

enum ShirtSize {
  p_fem
  m_fem
  g_fem
  gg_fem
  xg_fem
  p_masc
  m_masc
  g_masc
  gg_masc
  xg_masc
}

enum BankAccountOption {
  sim
  nao
  outra
}

model User {
  id          String    @id @default(cuid())
  name        String
  email       String    @unique
  password    String?
  role        UserRole  @default(employee)
  evaluationMode EvaluationMode @default(feedback)
  avatarUrl   String?
  ssoProvider String?
  ssoId       String?
  msAccessToken    String?
  msRefreshToken   String?
  msTokenExpiresAt DateTime?
  isActive    Boolean   @default(true)
  admissionDate DateTime?
  phone       String?
  cpf         String?   @unique
  birthDate   DateTime?
  jobTitle    String?
  address     String?
  city        String?
  state       String?
  zipCode     String?

  // Personal data fields
  rg              String?
  ethnicity       Ethnicity?
  gender          Gender?
  maritalStatus   MaritalStatus?
  educationLevel  EducationLevel?
  livesWithDescription String?

  // Contact
  personalEmail     String?
  addressNumber     String?
  addressComplement String?

  // Financial & Benefits
  hasBradescoAccount  BankAccountOption?
  bankAgency          String?
  bankAccount         String?
  hasOtherEmployment  Boolean?
  healthPlanOption    HealthPlanOption?
  wantsTransportVoucher Boolean?
  contractType        ContractType?
  shirtSize           ShirtSize?

  // Family
  hasChildren      Boolean?
  childrenAges     String?
  hasIRDependents  Boolean?

  // About Me
  hobbies                  String[]
  socialNetworks           Json?
  favoriteBookMovieGenres  String?
  favoriteBooks            String?
  favoriteMovies           String?
  favoriteMusic            String?
  admiredValues            String?
  foodAllergies            String?
  hasPets                  String?
  participateInVideos      Boolean?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations as employee
  employeeHierarchies EmployeeHierarchy[] @relation("Employee")
  pdisAsEmployee      PDI[]               @relation("PDIEmployee")
  feedbacksReceived   Feedback[]          @relation("FeedbackEmployee")
  feedbackSchedulesAsEmployee FeedbackSchedule[] @relation("FeedbackScheduleEmployee")

  // Relations as manager
  managerHierarchies  EmployeeHierarchy[] @relation("Manager")
  pdisAsManager       PDI[]               @relation("PDIManager")
  feedbacksGiven      Feedback[]          @relation("FeedbackManager")
  feedbackSchedulesAsManager FeedbackSchedule[] @relation("FeedbackScheduleManager")

  // Other relations
  pdiComments         PDIComment[]
  pdiEvidences        PDIEvidence[]
  goalResponsibilities PDIGoal[]     @relation("GoalResponsible")
  notifications       Notification[]
  dependents          Dependent[]
  emergencyContacts   EmergencyContact[]

  // Nine Box relations
  nineBoxEvaluationsReceived NineBoxEvaluation[] @relation("NineBoxEvaluatee")
  nineBoxEvaluationsCreated  NineBoxEvaluation[] @relation("NineBoxCreatedBy")
  nineBoxResponses           NineBoxEvaluator[]

  @@index([email])
  @@index([role])
  @@index([evaluationMode])
}

// ============================================================
// Organizational Structure
// ============================================================

model OrganizationalUnit {
  id        String   @id @default(cuid())
  name      String
  parentId  String?
  createdAt DateTime @default(now())

  parent   OrganizationalUnit?  @relation("OrgUnitHierarchy", fields: [parentId], references: [id])
  children OrganizationalUnit[] @relation("OrgUnitHierarchy")

  employeeHierarchies EmployeeHierarchy[]
  sectorSchedules     SectorSchedule[]

  @@index([parentId])
}

model SectorSchedule {
  id                   String       @id @default(cuid())
  organizationalUnitId String
  type                 ScheduleType
  frequencyMonths      Int
  startDate            DateTime
  isActive             Boolean      @default(true)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  organizationalUnit OrganizationalUnit @relation(fields: [organizationalUnitId], references: [id])

  @@unique([organizationalUnitId, type])
  @@index([organizationalUnitId])
}

model EmployeeHierarchy {
  id                   String   @id @default(cuid())
  employeeId           String
  managerId            String
  organizationalUnitId String
  startDate            DateTime @default(now())
  endDate              DateTime?

  employee           User               @relation("Employee", fields: [employeeId], references: [id])
  manager            User               @relation("Manager", fields: [managerId], references: [id])
  organizationalUnit OrganizationalUnit @relation(fields: [organizationalUnitId], references: [id])

  @@index([employeeId])
  @@index([managerId])
  @@index([organizationalUnitId])
}

// ============================================================
// PDI (Plano de Desenvolvimento Individual)
// ============================================================

enum PDIStatus {
  active
  cancelled
}

enum GoalStatus {
  pending
  in_progress
  completed
}

enum FollowUpStatus {
  scheduled
  completed
  cancelled
}

model PDI {
  id              String    @id @default(cuid())
  employeeId      String
  managerId       String
  status          PDIStatus @default(active)
  conductedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  employee  User @relation("PDIEmployee", fields: [employeeId], references: [id])
  manager   User @relation("PDIManager", fields: [managerId], references: [id])

  goals     PDIGoal[]
  comments  PDIComment[]
  followUps PDIFollowUp[]

  @@index([employeeId])
  @@index([managerId])
  @@index([status])
}

model PDIFollowUp {
  id              String         @id @default(cuid())
  pdiId           String
  scheduledAt     DateTime
  conductedAt     DateTime?
  notes           String?
  status          FollowUpStatus @default(scheduled)
  outlookEventId  String?
  createdAt       DateTime       @default(now())

  pdi PDI @relation(fields: [pdiId], references: [id], onDelete: Cascade)

  @@index([pdiId])
}

model PDIGoal {
  id                   String     @id @default(cuid())
  pdiId                String
  developmentObjective String
  actions              String?
  status               GoalStatus @default(pending)
  dueDate              DateTime?
  startDate            DateTime?
  expectedResults      String?
  responsibleId        String?
  completedAt          DateTime?
  successMetrics       String?
  achievedResults      String?
  createdAt            DateTime   @default(now())

  pdi         PDI           @relation(fields: [pdiId], references: [id], onDelete: Cascade)
  responsible User?         @relation("GoalResponsible", fields: [responsibleId], references: [id])
  evidences   PDIEvidence[]

  @@index([pdiId])
  @@index([status])
  @@index([responsibleId])
}

model PDIEvidence {
  id          String   @id @default(cuid())
  goalId      String
  authorId    String?
  description String
  fileUrl     String?
  createdAt   DateTime @default(now())

  goal   PDIGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)
  author User?   @relation(fields: [authorId], references: [id])

  @@index([goalId])
  @@index([authorId])
}

model PDIComment {
  id        String   @id @default(cuid())
  pdiId     String
  authorId  String
  content   String
  createdAt DateTime @default(now())

  pdi    PDI  @relation(fields: [pdiId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id])

  @@index([pdiId])
  @@index([authorId])
}

// ============================================================
// Feedback
// ============================================================

enum FeedbackStatus {
  draft
  scheduled
  submitted
  cancelled
}

model Feedback {
  id              String         @id @default(cuid())
  employeeId      String
  managerId       String
  period          String
  content         String?
  strengths       String?
  improvements    String?
  rating          Int?
  status          FeedbackStatus @default(draft)
  frequencyMonths Int?
  conductedAt     DateTime?
  scheduledAt     DateTime?
  isOnboarding    Boolean        @default(false)
  outlookEventId  String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  employee User @relation("FeedbackEmployee", fields: [employeeId], references: [id])
  manager  User @relation("FeedbackManager", fields: [managerId], references: [id])

  nineBoxEvaluation NineBoxEvaluation?

  @@index([employeeId])
  @@index([managerId])
  @@index([status])
  @@index([scheduledAt])
}

// ============================================================
// Scheduling
// ============================================================

model FeedbackSchedule {
  id              String   @id @default(cuid())
  employeeId      String
  managerId       String
  frequencyMonths Int
  nextDueDate     DateTime
  isActive        Boolean  @default(true)

  employee User @relation("FeedbackScheduleEmployee", fields: [employeeId], references: [id])
  manager  User @relation("FeedbackScheduleManager", fields: [managerId], references: [id])

  @@index([employeeId])
  @@index([managerId])
  @@index([nextDueDate])
}


// ============================================================
// Notifications
// ============================================================

enum NotificationType {
  pdi_reminder
  feedback_reminder
  feedback_scheduled
  feedback_submitted_auto
  ninebox_invite
  general
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  emailSent Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([isRead])
  @@index([type])
}

// ============================================================
// Nine Box
// ============================================================

enum NineBoxStatus {
  open
  closed
}

enum NineBoxEvaluatorStatus {
  pending
  completed
}

model NineBoxEvaluation {
  id          String       @id @default(cuid())
  feedbackId  String       @unique
  evaluateeId String
  createdById String
  status      NineBoxStatus @default(open)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  feedback  Feedback @relation(fields: [feedbackId], references: [id])
  evaluatee User     @relation("NineBoxEvaluatee", fields: [evaluateeId], references: [id])
  createdBy User     @relation("NineBoxCreatedBy", fields: [createdById], references: [id])

  evaluators NineBoxEvaluator[]

  @@index([feedbackId])
  @@index([evaluateeId])
  @@index([createdById])
  @@index([status])
}

model NineBoxEvaluator {
  id           String                 @id @default(cuid())
  evaluationId String
  evaluatorId  String
  status       NineBoxEvaluatorStatus @default(pending)

  // Desempenho (q1-q6)
  q1 Int?
  q2 Int?
  q3 Int?
  q4 Int?
  q5 Int?
  q6 Int?

  // Potencial (q7-q12)
  q7  Int?
  q8  Int?
  q9  Int?
  q10 Int?
  q11 Int?
  q12 Int?

  // Descritiva
  q13PontosFortes  String?
  q14Oportunidade  String?

  completedAt DateTime?
  createdAt   DateTime  @default(now())

  evaluation NineBoxEvaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  evaluator  User              @relation(fields: [evaluatorId], references: [id])

  @@unique([evaluationId, evaluatorId])
  @@index([evaluationId])
  @@index([evaluatorId])
}

// ============================================================
// HR: Dependents & Emergency Contacts
// ============================================================

model Dependent {
  id           String   @id @default(cuid())
  userId       String
  name         String
  relationship String
  cpf          String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model EmergencyContact {
  id           String   @id @default(cuid())
  userId       String
  name         String
  phone        String
  relationship String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}
