# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pdi_feedback?schema=public"

# NextAuth
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Azure AD SSO (optional - leave empty to disable Microsoft SSO)
AZURE_AD_CLIENT_ID=""
AZURE_AD_CLIENT_SECRET=""
AZURE_AD_TENANT_ID=""  # Directory (tenant) ID - restricts login to your org

# Email - SMTP (optional - logs to console if not configured)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="PDI Feedback HR <noreply@example.com>"

# Cron job authentication (optional - set to secure value in production)
CRON_SECRET=""
